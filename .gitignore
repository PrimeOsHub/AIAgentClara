@"
# Node / WhatsApp Dependencies
node_modules/
**/node_modules/

# Python Virtual Environments
venv/
.venv/
env/
__pycache__/
*.pyc

# Environment Variables and Keys
.env
config.private.json

# OpenClaw System Logs and Caches
logs/
.cache/
tmp/

# Credentials and Local Backups
credentials/
workspace/
*.bak
*.bak.*
*.json.last-good
update-check.json

# IDE Settings
.vscode/
.idea/
"@ | Out-File -FilePath .gitignore -Encoding utf8

# Ignore python virtual environments
venv/
.venv/
env/
__pycache__/
*.pyc

# Ignore environment variables and API keys
.env
config.private.json

# Ignore OpenClaw/system logs and temporary caches
logs/
.cache/
tmp/

# Credential files and workspace settings
credentials/
workspace/
*.bak
*.bak.*
*.json.last-good
update-check.json

# Ignore IDE/editor specific files
@"
npm/node_modules/
extensions/node_modules/
node_modules/
*.bak
*.bak.*
*.json.last-good
"@ | Out-File -FilePath .gitignore -Encoding utf8
# Ignore OpenClaw/system logs and temporary caches